#!/bin/bash
# AYA pre-push hook: auto-increment patch version on every push
#
# Bumps patch version in __init__.py, commits it, then pushes the
# extra commit. Uses AYA_VERSION_BUMPING env var to prevent recursion.

set -e

# Guard against recursion (this hook triggers another push)
if [ "${AYA_VERSION_BUMPING:-0}" = "1" ]; then
    exit 0
fi

INIT_FILE="src/aya/__init__.py"

if [ ! -f "$INIT_FILE" ]; then
    exit 0
fi

CURRENT=$(grep -oP '(?<=__version__ = ")[^"]+' "$INIT_FILE")
if [ -z "$CURRENT" ]; then
    exit 0
fi

IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$PATCH"

sed -i "s/__version__ = \"$CURRENT\"/__version__ = \"$NEW_VERSION\"/" "$INIT_FILE"
git add "$INIT_FILE"
git commit -m "Bump version $CURRENT → $NEW_VERSION" --no-verify

echo "AYA: version $CURRENT → $NEW_VERSION (will push after current push completes)"

# Schedule a background push of the version bump commit after this push finishes.
# The 1-second sleep gives the current push time to complete.
(
    sleep 1
    AYA_VERSION_BUMPING=1 git push --no-verify 2>/dev/null && \
        echo "AYA: version bump commit pushed" || true
) &
